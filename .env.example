DEVREL_GITHUB_TOKEN=ghp_...
DEVREL_GITHUB_REPO=generative-computing/mellea
DEVREL_GITHUB_PROJECT_ID=PVT_...

# LLM Backend Configuration
# Options: "ollama" (default), "openai", or "claude"
DEVREL_LLM_BACKEND=ollama
DEVREL_LLM_MODEL=granite3.3:8b

# Generic API Key (used by whichever backend is configured)
DEVREL_LLM_API_KEY=

# Ollama Configuration
# For local Ollama: http://localhost:11434
# For remote Ollama: https://ollama.example.com
DEVREL_OLLAMA_BASE_URL=http://localhost:11434
DEVREL_OLLAMA_API_KEY=

# OpenAI Configuration
DEVREL_OPENAI_API_KEY=

# Claude/Anthropic Configuration
DEVREL_ANTHROPIC_API_KEY=
